<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Título -->

        <!-- Descripción -->

        <!-- Imagen insertada abajo -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="BODEGA EL CAPIBARA"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:lineSpacingExtra="8dp"
            android:text="Somos unos jóvenes emprendedores que estamos creando una app de una bodega que ofrece productos frescos y variados. La premisa de nuestra bodega es hacerte la vida más fácil, reduciendo el tiempo en filas y llevando tus productos seleccionados a la puerta de su casa."
            android:textColor="@color/black"
            android:textSize="20sp" />

        <ImageView
            android:layout_width="355dp"
            android:layout_height="354dp"
            android:contentDescription="Imagen decorativa de la bodega"
            android:scaleType="centerCrop"
            android:src="@drawable/capi2" />
    </LinearLayout>
</ScrollView>
