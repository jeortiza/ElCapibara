<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgFondoMenu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_form02"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBienvenidaMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:text="BIENVENIDO\nJUNIOR"
        android:textColor="#E8C396"
        android:textSize="32sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMenuPrincipal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="60dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvBienvenidaMenu">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="60dp"> <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMenuProductos"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:text="PRODUCTOS"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:backgroundTint="#4A3424"
            app:cornerRadius="30dp"
            app:icon="@android:drawable/ic_menu_agenda"
            app:iconGravity="textEnd"
            app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenuVentas"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:text="REGISTRAR VENTA"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="#4A3424"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenuInventario"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:text="INVENTARIO"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="#4A3424"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenuReportes"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="24dp"
                android:text="REPORTES"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="#4A3424"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D3D3D3"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="BODEGA EL CAPIBARA"
                android:textColor="#757575"
                android:textSize="14sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/imgPerfilMenu"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo_capibara02"
        app:civ_border_color="#D7B692"
        app:civ_border_width="4dp"
        app:layout_constraintBottom_toTopOf="@+id/cardMenuPrincipal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cardMenuPrincipal" />

</androidx.constraintlayout.widget.ConstraintLayout>