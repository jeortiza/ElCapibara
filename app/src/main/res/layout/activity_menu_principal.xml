<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MenuPrincipalActivity">

    <ImageView
        android:id="@+id/imgFondoMenu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_form02"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnCerrarSesionIcono"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="24dp"
        android:src="@android:drawable/ic_lock_power_off"
        app:tint="#D32F2F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBienvenidaMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:text="BIENVENIDO\nJUNIOR"
        android:textColor="#E8C396"
        android:textSize="32sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/imgPerfilMenu"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/logo_capibara02"
        app:civ_border_color="#D7B692"
        app:civ_border_width="6dp"
        app:civ_circle_background_color="#FFFFFF"

        android:layout_marginTop="10dp"

        app:layout_constraintTop_toBottomOf="@+id/tvBienvenidaMenu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMenuPrincipal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"

        android:layout_marginTop="40dp"

        app:cardElevation="8dp"

        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"

        app:layout_constraintTop_toBottomOf="@+id/imgPerfilMenu"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="130dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="MENÚ PRINCIPAL"
                android:textColor="#333333"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenuProductos"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:text="PRODUCTOS"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="#4A3424"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenuVentas"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:text="REGISTRAR VENTA"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="#4A3424"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenuInventario"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:text="INVENTARIO"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="#4A3424"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenuReportes"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="24dp"
                android:text="REPORTES"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="#4A3424"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D3D3D3"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="BODEGA EL CAPIBARA"
                android:textColor="#757575"
                android:textSize="14sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>